# --- Claude API ---
ANTHROPIC_API_KEY=sk-ant-...
# Chat runs on Haiku (cheap, fast); config generation on Sonnet (quality). Override if needed.
CHAT_MODEL=claude-haiku-4-5
CONFIG_MODEL=claude-sonnet-5

# --- Supabase ---
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# --- Stripe ---
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Price for the $150/month subscription (create in Stripe dashboard)
STRIPE_PRICE_ID=price_...

# --- Growth engine (in-house lead gen + outreach) ---
# Google Places API key for discovery (10k free text-search requests/month).
# Leave unset to use CSV import (npm run import-leads) instead.
GOOGLE_PLACES_API_KEY=
# Daily discovery targets for the growth cron: "City ST:niche" pairs.
GROWTH_TARGETS="Austin TX:dentist,Denver CO:hvac"
# Businesses fetched per target per day / leads run through Claude per day.
GROWTH_DISCOVER_PER_TARGET=20
GROWTH_PIPELINE_BATCH=15

# --- Client notifications (lead alerts, morning digest, day-1 email) ---
# Sent from your PRIMARY domain — keep separate from the outreach domain.
NOTIFY_FROM_EMAIL="FrontDesk AI <hello@yourdomain.com>"

# --- Outreach sending (leave unset = dry-run mode, nothing is sent) ---
# Resend API key (free 3k emails/month). Use a warmed secondary domain,
# NOT your primary domain.
RESEND_API_KEY=
OUTREACH_FROM_EMAIL="Jo from FrontDesk AI <jo@get-frontdesk.com>"
OUTREACH_REPLY_TO=you@yourdomain.com
OUTREACH_SIGNATURE="Jo Pollard\nFrontDesk AI"
# CAN-SPAM: a real physical postal address is legally required in every email.
OUTREACH_PHYSICAL_ADDRESS="123 Main St, Suite 4, Austin TX 78701"
# Max outreach emails per day across all sequences (keep low while warming).
OUTREACH_DAILY_CAP=30

# --- App ---
# Public base URL (used for checkout redirects and embed snippets)
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Secret required by cron endpoints (set the same value in Vercel cron headers)
CRON_SECRET=change-me
